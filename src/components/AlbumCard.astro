---
interface Props {
  title: string;
  slug: string;
  releaseDate: string;
  label: string;
  type: 'solo' | 'btnth' | 'collab';
  coverImage?: string;
  featured?: boolean;
}

const { title, slug, releaseDate, label, type, coverImage, featured = false } = Astro.props;

const year = releaseDate.split('-')[0];

const typeLabels = {
  solo: 'Solo',
  btnth: 'Bone Thugs-N-Harmony',
  collab: 'Collaboration',
};
---

<a href={`/discography/${slug}`} class="album-card">
  <div class="card-inner">
    <div class="cover-wrap">
      {coverImage ? (
        <img src={`/covers/${coverImage}`} alt={title} class="cover-img" loading="lazy" />
      ) : (
        <div class="cover-placeholder"></div>
      )}
    </div>
    <div class="card-meta">
      <span class="year">{year}</span>
      <span class="album-title">{title}</span>
      <span class="label-type">{label} · {typeLabels[type]}</span>
    </div>
  </div>
</a>

<style>
  .album-card {
    display: block;
    text-decoration: none;
    position: relative;
    border-right: 0.5px solid #1a1a1a;
    border-bottom: 0.5px solid #1a1a1a;
    transition: background 0.2s;
    overflow: hidden;
  }
  .album-card:hover {
    background: #161616;
  }
  .card-inner {
    padding-left: 0;
  }
  .cover-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover-placeholder {
    width: 100%;
    height: 100%;
    background: #181818;
  }
  .card-meta {
    padding: 12px 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .year {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #c9a962;
    letter-spacing: 0.1em;
  }
  .album-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 13px;
    color: #e0e0e0;
    line-height: 1.3;
  }
  .label-type {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #444;
  }
</style>
