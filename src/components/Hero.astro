---
---

<header id="site-header" style="position:relative;width:100%;height:30vh;min-height:140px;max-height:260px;background:#0f0f0f;overflow:hidden;">

  <!-- Left: photo (40% width) -->
  <div id="hdr-img" style="position:absolute;top:0;left:0;width:40%;height:100%;background:#0f0f0f;">
    <img id="hero-img" src="/bizzy_bone_header.jpg" alt="Bizzy Bone" style="display:block;width:100%;height:100%;object-fit:contain;object-position:left center;" />
<div style="position:absolute;top:0;right:0;width:55%;height:100%;background:linear-gradient(to right,transparent,#0f0f0f);z-index:6;pointer-events:none;"></div>
  </div>

  <!-- Center: logo — absolutely centered in full header width -->
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);height:100%;width:40%;display:flex;align-items:center;justify-content:center;padding-top:20px;z-index:10;">
  <img src="/logo.png" alt="Bizzy Bone Music" style="display:block;width:80%;height:auto;opacity:0.30;" />
</div>

  <!-- Right: typewriter (rightmost 25%) -->
  <div id="hdr-type" style="position:absolute;top:0;right:0;width:25%;height:100%;display:flex;align-items:center;justify-content:center;padding:16px;">
    <div style="text-align:center;">
      <span id="typewriter-text" style="font-family:'Courier New',Courier,monospace;font-size:clamp(17px,1.96vw,28px);font-weight:400;color:#444;letter-spacing:0.08em;"></span><span id="typewriter-cursor" style="font-family:'Courier New',Courier,monospace;font-size:clamp(17px,1.96vw,28px);color:#444;">_</span>
    </div>
  </div>

</header>

<style>
  @media (max-width: 767px) {
    #site-header { flex-direction: column; height: auto; max-height: none; }
    #hdr-img     { flex: none; width: 100%; height: 44vw; min-height: 160px; }
    #hdr-type    { flex: none; width: 100%; padding: 12px; }
  }
</style>


<script>
(function () {
  const names = ['Bizzy Bone', 'Bryon McCane', 'BB Gambini', 'Lil Ripsta'];
  const textEl   = document.getElementById('typewriter-text');
  const cursorEl = document.getElementById('typewriter-cursor');
  if (!textEl || !cursorEl) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    textEl.textContent = names[0];
    cursorEl.style.display = 'none';
    return;
  }

  let nameIndex = 0, charIndex = 0, deleting = false;

  let cursorVisible = true;
  setInterval(() => {
    cursorVisible = !cursorVisible;
    cursorEl.style.opacity = cursorVisible ? '1' : '0';
  }, 600);

  function type() {
    const current = names[nameIndex];
    if (!deleting) {
      charIndex++;
      textEl.textContent = current.slice(0, charIndex);
      if (charIndex === current.length) {
        deleting = true;
        setTimeout(type, 3200);
        return;
      }
      setTimeout(type, 110);
    } else {
      charIndex--;
      textEl.textContent = current.slice(0, charIndex);
      if (charIndex === 0) {
        deleting = false;
        nameIndex = (nameIndex + 1) % names.length;
        setTimeout(type, 700);
        return;
      }
      setTimeout(type, 55);
    }
  }

  window.addEventListener('load', () => setTimeout(type, 1200));
})();
</script>
