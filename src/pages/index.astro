---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Nav from '../components/Nav.astro';
import AlbumGrid from '../components/AlbumGrid.astro';

const albums = await getCollection('discography');
---

<Base
  suppressSuffix title="Bizzy Bone — Complete Discography | All Albums 1993–2025"
  description="The complete Bizzy Bone discography — all 52 releases including solo albums, Bone Thugs-N-Harmony albums and collaborations. Release dates, labels, chart positions and where to buy."
>
  <Hero />
  <Nav />
  <AlbumGrid albums={albums} />
</Base>
