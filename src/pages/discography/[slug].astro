---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Tracklist from '../../components/Tracklist.astro';

export async function getStaticPaths() {
  const albums = await getCollection('discography');
  const sorted = [...albums].sort((a, b) => a.data.releaseDate.localeCompare(b.data.releaseDate));

  return sorted.map((album, i) => ({
    params: { slug: album.id },
    props: {
      album,
      prev: sorted[i - 1] || null,
      next: sorted[i + 1] || null,
    },
  }));
}

interface Props {
  album: CollectionEntry<'discography'>;
  prev: CollectionEntry<'discography'> | null;
  next: CollectionEntry<'discography'> | null;
}

const { album, prev, next } = Astro.props;
const { data } = album;
const year = data.releaseDate.split('-')[0];
const metaDescription = data.description.length > 155
  ? data.description.slice(0, 155).trimEnd() + '…'
  : data.description;
const ogImage = data.coverImage
  ? `https://bizzybonemusic.com/covers/${data.coverImage}`
  : 'https://bizzybonemusic.com/bizzy_bone_header.jpg';

const albumJsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicAlbum",
  "name": data.title,
  "datePublished": data.releaseDate,
  "description": data.description,
  "recordLabel": data.label,
  ...(data.coverImage && { "image": `https://bizzybonemusic.com/covers/${data.coverImage}` }),
  "numTracks": data.tracks.length,
  "byArtist": {
    "@type": "Person",
    "name": "Bizzy Bone",
    "birthName": "Bryon Anthony McCane II",
    "birthDate": "1976-09-12",
    "birthPlace": "Cleveland, Ohio"
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Discography", "item": "https://bizzybonemusic.com" },
    { "@type": "ListItem", "position": 2, "name": data.title, "item": `https://bizzybonemusic.com/discography/${album.id}` }
  ]
};
---

<Base
  title={data.title}
  description={metaDescription}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(albumJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <div style="min-height:100vh;background:#0f0f0f;">
    <Nav />

    <main style="max-width:1200px;margin:0 auto;padding:64px 48px 80px;">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>→</span>
        <a href="/#discography">Discography</a>
        <span>→</span>
        <span style="color:#777;">{data.title}</span>
      </nav>

      <!-- Main content -->
      <div class="album-layout">
        <!-- Cover image -->
        <div class="cover-col">
          {data.coverImage ? (
            <img
              src={`/covers/${data.coverImage}`}
              alt={`${data.title} cover`}
              class="album-cover"
            />
          ) : (
            <div class="cover-placeholder"></div>
          )}
        </div>

        <!-- Details -->
        <div class="details-col">
          <h1 class="album-title">{data.title}</h1>
          <p class="release-info">{year} · {data.label}</p>

          {data.certification && (
            <span class="badge">{data.certification}</span>
          )}

          {data.chartPeak && (
            <p class="chart-peak">{data.chartPeak}</p>
          )}

          <p class="description" set:html={data.description} />

          {data.quote && (
            <blockquote class="pull-quote">
              <p>"{data.quote}"</p>
              {data.quoteSong && <cite>— {data.quoteSong}</cite>}
            </blockquote>
          )}

          {data.tracks && data.tracks.length > 0 && (
            <Tracklist tracks={data.tracks} />
          )}

          {data.buyLink && (
            <a href={data.buyLink} target="_blank" rel="noopener noreferrer" class="buy-btn">
              {data.buyLinkType === 'official' && 'Buy from artist →'}
              {data.buyLinkType === 'amazon' && 'Buy on Amazon →'}
              {data.buyLinkType === 'discogs' && 'Find on Discogs →'}
              {data.buyLinkType === 'ebay' && 'Find on eBay →'}
              {!data.buyLinkType && 'Buy / Stream →'}
            </a>
          )}
        </div>
      </div>

      <!-- Prev / Next -->
      <div class="prev-next">
        {prev ? (
          <a href={`/discography/${prev.id}`} class="nav-link-prev">
            ← {prev.data.title}
          </a>
        ) : <div />}
        {next ? (
          <a href={`/discography/${next.id}`} class="nav-link-next">
            {next.data.title} →
          </a>
        ) : <div />}
      </div>
    </main>
  </div>

  {album.id === 'the-wonder-years' && (
    <div id="ufo-overlay">
      <img id="ufo-ship" src="/ufo.png" alt="" aria-hidden="true" />
      <div id="ufo-beam-wrapper"><div id="ufo-beam"></div></div>
      <img id="ufo-alien" src="/varginha.png" alt="" aria-hidden="true" />
    </div>
  )}

  {album.id === 'mr-ouija' && (
    <div id="ouija-overlay">
      <img id="ouija-image" src="/ouija.png" alt="" aria-hidden="true" />
    </div>
  )}
</Base>

<script>
(function () {
  const trigger = document.getElementById('varginha-trigger');
  if (!trigger) return;

  const overlay = document.getElementById('ufo-overlay');
  const ship    = document.getElementById('ufo-ship');
  const beam    = document.getElementById('ufo-beam-wrapper');
  const alien   = document.getElementById('ufo-alien');

  let audio = null;
  let animating = false;
  let holdTimer = null;

  function fadeOutAudio(duration = 1000) {
    if (!audio) return;
    const start = audio.volume;
    const step = 50;
    const decrement = start / (duration / step);
    const fade = setInterval(() => {
      if (audio.volume > decrement) {
        audio.volume = Math.max(0, audio.volume - decrement);
      } else {
        audio.volume = 0;
        audio.pause();
        clearInterval(fade);
      }
    }, step);
  }

  function closeAnimation() {
    if (!animating) return;
    animating = false;
    if (holdTimer) { clearTimeout(holdTimer); holdTimer = null; }

    alien.classList.remove('visible');
    setTimeout(() => beam.classList.remove('visible'), 400);
    setTimeout(() => {
      ship.classList.remove('flying-in');
      ship.classList.add('flying-out');
    }, 700);
    setTimeout(() => overlay.classList.remove('fading-in'), 900);
    setTimeout(() => {
      overlay.classList.remove('active');
      ship.style.transition = 'none';
      ship.classList.remove('flying-out');
      void ship.offsetWidth;
    }, 1600);

    fadeOutAudio(900);
  }

  function runAnimation() {
    if (animating) return;
    animating = true;

    ship.classList.remove('flying-in', 'flying-out');
    beam.classList.remove('visible');
    alien.classList.remove('visible');
    overlay.classList.remove('fading-in');
    ship.style.transition = 'none';
    ship.style.left = 'calc(100vw + 200px)';
    void ship.offsetWidth;

    overlay.classList.add('active');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        overlay.classList.add('fading-in');
      });
    });

    try {
      if (audio) { audio.pause(); audio.currentTime = 0; }
      audio = new Audio('/ufo_sound.mp3');
      audio.volume = 0.7;
      audio.play().catch(() => {});
    } catch(e) {}

    setTimeout(() => {
      ship.style.transition = '';
      ship.style.left = '';
      ship.classList.add('flying-in');
    }, 400);

    setTimeout(() => beam.classList.add('visible'), 1900);
    setTimeout(() => alien.classList.add('visible'), 2600);

    holdTimer = setTimeout(() => {
      closeAnimation();
    }, 6600);
  }

  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    runAnimation();
  });

  overlay.addEventListener('click', () => {
    closeAnimation();
  });
})();
</script>

<script>
(function () {
  const trigger = document.getElementById('ouija-trigger');
  if (!trigger) return;

  const overlay = document.getElementById('ouija-overlay');
  const image   = document.getElementById('ouija-image');

  let audio = null;
  let animating = false;
  let holdTimer = null;

  function fadeOutAudio(duration = 500) {
    if (!audio) return;
    const step = 50;
    const decrement = audio.volume / (duration / step);
    const fade = setInterval(() => {
      if (audio.volume > decrement) {
        audio.volume = Math.max(0, audio.volume - decrement);
      } else {
        audio.volume = 0;
        audio.pause();
        clearInterval(fade);
      }
    }, step);
  }

  function closeAnimation() {
    if (!animating) return;
    animating = false;
    if (holdTimer) { clearTimeout(holdTimer); holdTimer = null; }

    image.classList.remove('visible');
    setTimeout(() => overlay.classList.remove('fading-in'), 800);
    setTimeout(() => {
      overlay.classList.remove('active');
    }, 1400);

    fadeOutAudio(500);
  }

  function runAnimation() {
    if (animating) return;
    animating = true;

    image.classList.remove('visible');
    overlay.classList.remove('fading-in');

    overlay.classList.add('active');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        overlay.classList.add('fading-in');
      });
    });

    try {
      if (audio) { audio.pause(); audio.currentTime = 0; }
      audio = new Audio('/ouija_sound.mp3');
      audio.volume = 0;
      audio.play().catch(() => {});
      const step = 50;
      const target = 0.7;
      const increment = target / (500 / step);
      const fadeIn = setInterval(() => {
        if (audio.volume < target - increment) {
          audio.volume = Math.min(target, audio.volume + increment);
        } else {
          audio.volume = target;
          clearInterval(fadeIn);
        }
      }, step);
    } catch(e) {}

    setTimeout(() => image.classList.add('visible'), 400);

    audio.addEventListener('ended', () => {
      holdTimer = setTimeout(() => closeAnimation(), 500);
    });
  }

  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    runAnimation();
  });

  overlay.addEventListener('click', () => {
    closeAnimation();
  });
})();
</script>

<style>
  .breadcrumb {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #555;
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 48px;
  }
  .breadcrumb a {
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: #c9a962;
  }

  .album-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 64px;
    align-items: start;
  }

  .cover-col {}

  .album-cover {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .cover-placeholder {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    background: #181818;
  }

  .details-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .album-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 300;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 0;
    line-height: 1.05;
  }

  .release-info {
    font-family: 'Courier New', monospace;
    font-size: 12px;
    color: #555;
    margin: 0;
  }

  .badge {
    display: inline-block;
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #c9a962;
    border: 0.5px solid #c9a962;
    padding: 4px 12px;
  }

  .chart-peak {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #555;
    margin: 0;
  }

  .description {
    font-size: 15px;
    color: #888;
    line-height: 1.75;
    margin: 0;
  }

  .pull-quote {
    border-left: 2px solid #c9a962;
    padding-left: 16px;
    margin: 0;
  }
  .pull-quote p {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    color: #777;
    margin: 0 0 8px 0;
    font-size: 15px;
    line-height: 1.6;
  }
  .pull-quote cite {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #555;
    font-style: normal;
  }

  .buy-btn {
    display: inline-block;
    font-family: 'Courier New', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #c9a962;
    border: 0.5px solid #c9a962;
    padding: 8px 24px;
    text-decoration: none;
    transition: all 0.2s;
    align-self: flex-start;
  }
  .buy-btn:hover {
    background: #c9a962;
    color: #000;
  }

  .prev-next {
    display: flex;
    justify-content: space-between;
    margin-top: 80px;
    padding-top: 24px;
    border-top: 0.5px solid #1a1a1a;
  }
  .nav-link-prev,
  .nav-link-next {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link-prev:hover,
  .nav-link-next:hover {
    color: #c9a962;
  }

  :global(#varginha-trigger) {
    cursor: pointer;
  }

  :global(#ufo-overlay) {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    z-index: 9999;
    cursor: pointer;
    transition: background 0.6s ease;
  }
  :global(#ufo-overlay.active) {
    display: block;
  }
  :global(#ufo-overlay.fading-in) {
    background: rgba(0, 0, 0, 0.85);
  }
  :global(#ufo-ship) {
    position: absolute;
    width: 380px;
    height: auto;
    top: 15vh;
    left: calc(100vw + 200px);
    transition: none;
    filter: drop-shadow(0 0 20px rgba(100, 255, 100, 0.6));
    z-index: 2;
  }
  :global(#ufo-ship.flying-in) {
    transition: left 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    left: calc(50vw - 190px);
  }
  :global(#ufo-ship.flying-out) {
    transition: left 1.0s cubic-bezier(0.55, 0, 0.75, 0.06);
    left: calc(-500px);
  }
  :global(#ufo-beam-wrapper) {
    position: absolute;
    top: calc(15vh + 190px);
    left: calc(50vw - 150px);
    width: 300px;
    height: 350px;
    opacity: 0;
    transition: opacity 0.8s ease;
    pointer-events: none;
    filter: blur(18px);
    z-index: 1;
  }
  :global(#ufo-beam-wrapper.visible) {
    opacity: 1;
  }
  :global(#ufo-beam) {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(120, 255, 120, 0.55) 0%,
      rgba(80, 255, 80, 0.18) 70%,
      rgba(60, 220, 60, 0.04) 100%
    );
    clip-path: polygon(25% 0%, 75% 0%, 100% 100%, 0% 100%);
  }
  :global(#ufo-alien) {
    position: absolute;
    width: 260px;
    height: auto;
    top: calc(15vh + 330px);
    left: calc(50vw - 130px);
    opacity: 0;
    transition: opacity 1.0s ease;
    pointer-events: none;
    filter: drop-shadow(0 0 12px rgba(80, 255, 80, 0.8));
  }
  :global(#ufo-alien.visible) {
    opacity: 1;
  }

  :global(#ouija-overlay) {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    z-index: 9999;
    cursor: pointer;
    transition: background 0.6s ease;
  }
  :global(#ouija-overlay.active) {
    display: block;
  }
  :global(#ouija-overlay.fading-in) {
    background: rgba(0, 0, 0, 0.85);
  }
  :global(#ouija-image) {
    position: absolute;
    width: 500px;
    height: auto;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 1.0s ease;
    pointer-events: none;
  }
  :global(#ouija-image.visible) {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .album-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    main {
      padding: 24px 24px 60px !important;
    }
  }
</style>
