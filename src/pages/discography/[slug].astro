---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Tracklist from '../../components/Tracklist.astro';

export async function getStaticPaths() {
  const albums = await getCollection('discography');
  const sorted = [...albums].sort((a, b) => a.data.releaseDate.localeCompare(b.data.releaseDate));

  return sorted.map((album, i) => ({
    params: { slug: album.id },
    props: {
      album,
      prev: sorted[i - 1] || null,
      next: sorted[i + 1] || null,
    },
  }));
}

interface Props {
  album: CollectionEntry<'discography'>;
  prev: CollectionEntry<'discography'> | null;
  next: CollectionEntry<'discography'> | null;
}

const { album, prev, next } = Astro.props;
const { data } = album;
const year = data.releaseDate.split('-')[0];
const metaDescription = data.description.length > 155
  ? data.description.slice(0, 155).trimEnd() + '…'
  : data.description;
const ogImage = data.coverImage
  ? `https://bizzybonemusic.com/covers/${data.coverImage}`
  : 'https://bizzybonemusic.com/bizzy_bone_header.jpg';

const albumJsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicAlbum",
  "name": data.title,
  "datePublished": data.releaseDate,
  "description": data.description,
  "recordLabel": data.label,
  ...(data.coverImage && { "image": `https://bizzybonemusic.com/covers/${data.coverImage}` }),
  "numTracks": data.tracks.length,
  "byArtist": {
    "@type": "Person",
    "name": "Bizzy Bone",
    "birthName": "Bryon Anthony McCane II",
    "birthDate": "1976-09-12",
    "birthPlace": "Cleveland, Ohio"
  }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Discography", "item": "https://bizzybonemusic.com" },
    { "@type": "ListItem", "position": 2, "name": data.title, "item": `https://bizzybonemusic.com/discography/${album.id}` }
  ]
};
---

<Base
  title={data.title}
  description={metaDescription}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(albumJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <div style="min-height:100vh;background:#0f0f0f;">
    <Nav />

    <main style="max-width:1200px;margin:0 auto;padding:64px 48px 80px;">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>→</span>
        <a href="/#discography">Discography</a>
        <span>→</span>
        <span style="color:#777;">{data.title}</span>
      </nav>

      <!-- Main content -->
      <div class="album-layout">
        <!-- Cover image -->
        <div class="cover-col">
          {data.coverImage ? (
            <img
              src={`/covers/${data.coverImage}`}
              alt={`${data.title} cover`}
              class="album-cover"
            />
          ) : (
            <div class="cover-placeholder"></div>
          )}
        </div>

        <!-- Details -->
        <div class="details-col">
          <h1 class="album-title">{data.title}</h1>
          <p class="release-info">{year} · {data.label}</p>

          {data.certification && (
            <span class="badge">{data.certification}</span>
          )}

          {data.chartPeak && (
            <p class="chart-peak">{data.chartPeak}</p>
          )}

          <p class="description" set:html={data.description} />

          {data.quote && (
            <blockquote class="pull-quote">
              <p>"{data.quote}"</p>
              {data.quoteSong && <cite>— {data.quoteSong}</cite>}
            </blockquote>
          )}

          {data.tracks && data.tracks.length > 0 && (
            <Tracklist tracks={data.tracks} />
          )}

          {data.buyLink && (
            <a href={data.buyLink} target="_blank" rel="noopener noreferrer" class="buy-btn">
              {data.buyLinkType === 'official' && 'Buy from artist →'}
              {data.buyLinkType === 'amazon' && 'Buy on Amazon →'}
              {data.buyLinkType === 'discogs' && 'Find on Discogs →'}
              {data.buyLinkType === 'ebay' && 'Find on eBay →'}
              {!data.buyLinkType && 'Buy / Stream →'}
            </a>
          )}
        </div>
      </div>

      <!-- Prev / Next -->
      <div class="prev-next">
        {prev ? (
          <a href={`/discography/${prev.id}`} class="nav-link-prev">
            ← {prev.data.title}
          </a>
        ) : <div />}
        {next ? (
          <a href={`/discography/${next.id}`} class="nav-link-next">
            {next.data.title} →
          </a>
        ) : <div />}
      </div>
    </main>
  </div>

  {album.id === 'the-wonder-years' && (
    <>
      <div id="ufo-overlay" aria-hidden="true">
        <div id="ufo-screen-overlay"></div>
        <div id="ufo-unit">
          <img id="ufo-svg" src="/ufo.png" alt="UFO" />
        </div>
        <div id="ufo-beam"></div>
        <img id="varginha-img" src="/varginha.png" alt="Varginha" />
      </div>

      <script>
        console.log('easter egg loaded');
        const trigger = document.getElementById('varginha-trigger');
        console.log('trigger found:', trigger);
        const overlay = document.getElementById('ufo-overlay');
        const ufo = document.getElementById('ufo-unit');
        const beam = document.getElementById('ufo-beam');
        const screenOverlay = document.getElementById('ufo-screen-overlay');
        const img = document.getElementById('varginha-img');
        const sound = new Audio('/ufo_sound.mp3');
        sound.volume = 0.6;

        if (trigger && overlay) {
          trigger.addEventListener('click', () => {
            sound.currentTime = 0;
            sound.play();

            overlay.classList.add('active');
            ufo.classList.add('landed');

            setTimeout(() => beam.classList.add('active'), 2100); // 1600ms landing + 500ms pause
            setTimeout(() => img.classList.add('visible'), 2600);

            setTimeout(() => {
              img.classList.remove('visible');
              setTimeout(() => beam.classList.remove('active'), 400);   // 5400ms
              setTimeout(() => {                                         // 5800ms
                ufo.classList.add('exiting');
                setTimeout(() => {
                  ufo.classList.remove('landed');
                  ufo.classList.remove('exiting');
                }, 1300);
              }, 800);
              setTimeout(() => overlay.classList.remove('active'), 2000); // 7000ms
              const fadeOut = setInterval(() => {
                if (sound.volume > 0.05) {
                  sound.volume -= 0.05;
                } else {
                  sound.volume = 0;
                  sound.pause();
                  sound.currentTime = 0;
                  clearInterval(fadeOut);
                }
              }, 100);
            }, 5000);
          });

          screenOverlay.addEventListener('click', () => {
            sound.pause();
            sound.currentTime = 0;
            sound.volume = 0.6;
            img.classList.remove('visible');
            beam.classList.remove('active');
            ufo.classList.remove('landed');
            setTimeout(() => overlay.classList.remove('active'), 400);
          });
        }
      </script>
    </>
  )}
</Base>

<style>
  .breadcrumb {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #555;
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 48px;
  }
  .breadcrumb a {
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: #c9a962;
  }

  .album-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 64px;
    align-items: start;
  }

  .cover-col {}

  .album-cover {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .cover-placeholder {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    background: #181818;
  }

  .details-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .album-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 300;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 0;
    line-height: 1.05;
  }

  .release-info {
    font-family: 'Courier New', monospace;
    font-size: 12px;
    color: #555;
    margin: 0;
  }

  .badge {
    display: inline-block;
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #c9a962;
    border: 0.5px solid #c9a962;
    padding: 4px 12px;
  }

  .chart-peak {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #555;
    margin: 0;
  }

  .description {
    font-size: 15px;
    color: #888;
    line-height: 1.75;
    margin: 0;
  }

  .pull-quote {
    border-left: 2px solid #c9a962;
    padding-left: 16px;
    margin: 0;
  }
  .pull-quote p {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    color: #777;
    margin: 0 0 8px 0;
    font-size: 15px;
    line-height: 1.6;
  }
  .pull-quote cite {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #555;
    font-style: normal;
  }

  .buy-btn {
    display: inline-block;
    font-family: 'Courier New', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #c9a962;
    border: 0.5px solid #c9a962;
    padding: 8px 24px;
    text-decoration: none;
    transition: all 0.2s;
    align-self: flex-start;
  }
  .buy-btn:hover {
    background: #c9a962;
    color: #000;
  }

  .prev-next {
    display: flex;
    justify-content: space-between;
    margin-top: 80px;
    padding-top: 24px;
    border-top: 0.5px solid #1a1a1a;
  }
  .nav-link-prev,
  .nav-link-next {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link-prev:hover,
  .nav-link-next:hover {
    color: #c9a962;
  }

  :global(#ufo-overlay) {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.85);
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-top: 12vh;
    overflow: hidden;
  }
  :global(#ufo-overlay.active) {
    display: flex;
  }
  :global(#ufo-unit) {
    display: flex;
    justify-content: center;
    transform: translateX(900px);
    transition: transform 1.6s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
    width: 100%;
  }
  :global(#ufo-unit.landed) {
    transform: translateX(0);
  }
  :global(#ufo-unit.exiting) {
    transform: translateX(-1200px);
    transition: transform 1.2s cubic-bezier(0.7, 0, 1, 0.3);
  }
  :global(#ufo-svg) {
    width: 400px;
    z-index: 2;
  }
  :global(#ufo-beam) {
    width: 400px;
    height: 0;
    background: linear-gradient(to bottom, rgba(80, 255, 80, 0.6) 0%, rgba(80, 255, 80, 0.08) 70%, transparent 100%);
    clip-path: polygon(35% 0%, 65% 0%, 100% 100%, 0% 100%);
    filter: blur(8px);
    opacity: 0;
    transition: height 0.8s ease, opacity 0.8s ease;
    margin-top: -8px;
    z-index: 1;
    flex-shrink: 0;
  }
  :global(#ufo-beam.active) {
    height: 380px;
    opacity: 1;
  }
  :global(#ufo-screen-overlay) {
    position: fixed;
    inset: 0;
    z-index: 0;
    cursor: pointer;
  }
  :global(#varginha-img) {
    position: absolute;
    bottom: 18%;
    width: 280px;
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.8s ease;
    z-index: 3;
    filter: brightness(1.4) contrast(1.2);
  }
  :global(#varginha-img.visible) {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .album-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    main {
      padding: 24px 24px 60px !important;
    }
  }
</style>
